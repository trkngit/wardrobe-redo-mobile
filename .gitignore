# Archive
*.xcarchive

# Benchmark scratch space (DeepFashion2 + dev reports)
# The canonical location is ~/wardrobe-benchmark/, which is already under $HOME;
# this rule is belt-and-suspenders in case anyone points the tool at the repo.
wardrobe-benchmark/
benchmark_results/
scripts/benchmark-tool/.build/

# Python bytecode (from local script runs)
__pycache__/
*.py[cod]

# Python virtualenv (used by scripts/fetch_fixtures.py + scripts/build_benchmark.py)
.venv/
.venv-train/
venv/

# ML training artifacts — bulk binaries, not shipped
notebooks/training/checkpoints-p2/
notebooks/training/checkpoints/
rf-detr-seg-small.pt
*.pth
# fp16 mlpackage is the un-palettized debug variant — 122MB, not shipped.
# The production (palettized) RFDETRSegFashion.mlpackage IS committed.
WardrobeReDo/Models/CoreML/RFDETRSegFashion_fp16.mlpackage/
