{
  "sourceLanguage": "en",
  "strings": {
    "%lld found": {
      "comment": "Match results count (e.g. \"3 found\")",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld bulundu"
          }
        }
      }
    },
    "%lld items": {
      "comment": "Wardrobe count line (plural)",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ürün"
          }
        }
      }
    },
    "%lld outfits": {
      "comment": "Outfit count in the Outfits header",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld kombin"
          }
        }
      }
    },
    "1 item": {
      "comment": "Wardrobe count line (singular)",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "1 ürün"
          }
        }
      }
    },
    "8+ characters, uppercase, lowercase, and a number": {
      "comment": "AuthViewModel.passwordValidationMessage",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "8+ karakter, büyük harf, küçük harf ve bir rakam"
          }
        }
      }
    },
    "A balanced look": {
      "comment": "Vibe tagline",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dengeli bir görünüm"
          }
        }
      }
    },
    "About": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hakkında"
          }
        }
      }
    },
    "Accessories": {
      "comment": "Category — plural form",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aksesuarlar"
          }
        }
      }
    },
    "Account created. Check %@ for a confirmation link, then sign in.": {
      "comment": "AuthViewModel.signUp infoMessage after email confirmation needed",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesap oluşturuldu. %@ adresine gelen doğrulama bağlantısını aç, sonra giriş yap."
          }
        }
      }
    },
    "Account creation is currently unavailable. The team has been notified.": {
      "comment": "AuthError.databaseSignupFailure",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesap oluşturma şu anda kullanılamıyor. Ekip bilgilendirildi."
          }
        }
      }
    },
    "Add First Item": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlk Ürünü Ekle"
          }
        }
      }
    },
    "Add Item": {
      "comment": "AddItemView navigation title",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ürün Ekle"
          }
        }
      }
    },
    "Add a few items to start generating outfits.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kombin oluşturmaya başlamak için birkaç ürün ekle."
          }
        }
      }
    },
    "Add a photo": {
      "comment": "AddItemView empty state",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotoğraf ekle"
          }
        }
      }
    },
    "Add an Item": {
      "comment": "Failure-state deep-link CTA to the Wardrobe Add sheet",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ürün Ekle"
          }
        }
      }
    },
    "Add at least one more item — outfits need at least two pieces.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir ürün daha ekle — kombinler en az iki parçaya ihtiyaç duyar."
          }
        }
      }
    },
    "Add items to your wardrobe first": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önce gardırobuna ürün ekle"
          }
        }
      }
    },
    "Add more variety to your wardrobe to generate outfits.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kombin oluşturmak için gardırobuna çeşit ekle."
          }
        }
      }
    },
    "Add your first item to get started with personalized outfit suggestions.": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kişiselleştirilmiş kombin önerileri için ilk ürününü ekle."
          }
        }
      }
    },
    "Adventurous": {
      "comment": "Vibe stop label",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cesur"
          }
        }
      }
    },
    "Adventurous mix": {
      "comment": "Vibe tagline",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cesur karışım"
