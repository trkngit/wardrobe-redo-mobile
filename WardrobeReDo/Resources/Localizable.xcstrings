      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arşivlenen ürünler gardırobundan ve kombin önerilerinden gizlenir. Daha sonra arşiv görünümünden geri yükleyebilirsin."
