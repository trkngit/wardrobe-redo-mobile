# Core ML models are binary and can be large (the SAM2-tiny bundle is
# ~40 MB). Track them via Git LFS so clones and diffs stay fast, and
# committed blobs don't bloat the repo history.
#
# `.mlmodelc` is the compiled form that ships in the app bundle — it's
# actually a directory, so we LFS every file inside it.
*.mlmodelc filter=lfs diff=lfs merge=lfs -text
*.mlmodelc/** filter=lfs diff=lfs merge=lfs -text
*.mlmodel filter=lfs diff=lfs merge=lfs -text
*.mlpackage filter=lfs diff=lfs merge=lfs -text
*.mlpackage/** filter=lfs diff=lfs merge=lfs -text
